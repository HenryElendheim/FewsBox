<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Bare bones: Compose owns all real theming. This just makes sure the
         window is dark from the very first frame, no white flash on launch. -->
    <style name="Theme.FewsBox" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/launch_background</item>
        <item name="android:statusBarColor">@color/launch_background</item>
        <item name="android:navigationBarColor">@color/launch_background</item>
    </style>
</resources>
